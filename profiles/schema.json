{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ibcmd-rs.invalid/schemas/profile-v1.json",
  "title": "ibcmd-rs standalone conversion profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "$ref": "#/$defs/openIdentifier"
    },
    "extends": {
      "$ref": "#/$defs/openIdentifier"
    },
    "status": {
      "enum": [
        "experimental",
        "verified"
      ]
    },
    "platform_build": {
      "$ref": "#/$defs/dottedVersion"
    },
    "xml_dialect": {
      "$ref": "#/$defs/dottedVersion"
    },
    "compatibility_mode": {
      "$ref": "#/$defs/versionIdentifier"
    },
    "storage_profile": {
      "$ref": "#/$defs/openIdentifier"
    },
    "container_revision": {
      "$ref": "#/$defs/versionIdentifier"
    },
    "dbms": {
      "$ref": "#/$defs/openIdentifier"
    },
    "fingerprints": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "constants": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/openIdentifier"
      },
      "additionalProperties": {
        "enum": [
          "supported",
          "unsupported"
        ]
      }
    }
  },
  "$defs": {
    "openIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._:-]{0,126}[A-Za-z0-9])?$"
    },
    "versionIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
    },
    "dottedVersion": {
      "type": "string",
      "description": "Two to eight canonical unsigned 32-bit decimal components.",
      "pattern": "^(?:(?:0|[1-9][0-9]{0,8}|[1-3][0-9]{9}|4[0-1][0-9]{8}|42[0-8][0-9]{7}|429[0-3][0-9]{6}|4294[0-8][0-9]{5}|42949[0-5][0-9]{4}|429496[0-6][0-9]{3}|4294967[0-1][0-9]{2}|42949672[0-8][0-9]|429496729[0-5])\\.){1,7}(?:0|[1-9][0-9]{0,8}|[1-3][0-9]{9}|4[0-1][0-9]{8}|42[0-8][0-9]{7}|429[0-3][0-9]{6}|4294[0-8][0-9]{5}|42949[0-5][0-9]{4}|429496[0-6][0-9]{3}|4294967[0-1][0-9]{2}|42949672[0-8][0-9]|429496729[0-5])$"
    }
  }
}
